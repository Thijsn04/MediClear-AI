# ════════════════════════════════════════════════════════════
#  MediClear AI - Environment Configuration
#  Copy to .env and fill in your values. Never commit .env.
# ════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
ENVIRONMENT=production
# Hard cap on request body size (bytes). Rejected before buffering.
MAX_REQUEST_BODY_BYTES=12582912

# ── AI Provider ────────────────────────────────────────────
# gemini | openai | anthropic
AI_PROVIDER=gemini
# Optional ordered failover, tried if the primary fails. e.g. openai,anthropic
AI_FALLBACK_PROVIDERS=
AI_REQUEST_TIMEOUT_SECONDS=60
AI_MAX_RETRIES=2
AI_MAX_OUTPUT_TOKENS=4096
AI_TEMPERATURE=0.2

# ── Google Gemini ──────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── OpenAI / OpenAI-compatible (Ollama, Azure, Groq, vLLM, LM Studio) ──
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
# Ollama: http://localhost:11434/v1 · Groq: https://api.groq.com/openai/v1
OPENAI_BASE_URL=

# ── Anthropic Claude ───────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Clarification quality ──────────────────────────────────
# A2 (simplest) | B1 | B2
TARGET_READING_LEVEL=B1
ENFORCE_READING_LEVEL=true
MAX_SIMPLIFICATION_PASSES=1

# ── Result cache ───────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400
CACHE_MAX_ENTRIES=1024

# ── Sessions & Redis ───────────────────────────────────────
SESSION_TTL_SECONDS=3600
MAX_SESSIONS=1000
# Set for durable, multi-instance sessions/cache/rate-limit. Empty = in-memory.
REDIS_URL=

# ── Privacy & retention ────────────────────────────────────
# When true, nothing derived from the document is stored (chat disabled).
ZERO_RETENTION=false
REDACT_LOGS=true
AUDIT_LOGGING=true

# ── Uploads & OCR ──────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
# OCR scanned PDFs (requires the [ocr] extra + tesseract/poppler on the host).
ENABLE_OCR=true

# ── Text-to-speech ─────────────────────────────────────────
# gtts (cloud) | local (offline, needs [tts-local] + espeak) | disabled
TTS_BACKEND=gtts

# ── Authentication ─────────────────────────────────────────
REQUIRE_API_KEY=false
# Comma-separated keys, e.g. API_KEYS=key1,key2
API_KEYS=

# ── Rate limiting ──────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Frontend & observability ───────────────────────────────
ENABLE_FRONTEND=true
METRICS_ENABLED=true

# ── CORS ───────────────────────────────────────────────────
# Restrict in production, e.g. ALLOWED_ORIGINS=["https://mediclear.example.com"]
# Credentials are auto-disabled while this is the wildcard ["*"].
ALLOWED_ORIGINS=["*"]
