# ════════════════════════════════════════════════════════════
#  MediClear AI — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── AI Provider ────────────────────────────────────────────
# Choose one: gemini | openai | anthropic
AI_PROVIDER=gemini

# ── Google Gemini ──────────────────────────────────────────
# Any model your API key can access, for example:
#   gemini-2.5-flash | gemini-2.5-pro | gemini-1.5-pro
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── OpenAI / OpenAI-compatible ─────────────────────────────
# Any model string accepted by the target API, for example:
#   gpt-4o | gpt-4.1 | o3 | gpt-4o-mini         (OpenAI)
#   llama3.2 | mistral | phi4                     (Ollama)
#   meta-llama/Llama-3-70b-chat-hf               (Groq/Together)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
# Leave empty for OpenAI. Override for compatible APIs:
#   Ollama:    http://localhost:11434/v1
#   Groq:      https://api.groq.com/openai/v1
#   LM Studio: http://localhost:1234/v1
#   Azure:     https://<resource>.openai.azure.com/openai/deployments/<deployment>
OPENAI_BASE_URL=

# ── Anthropic Claude ───────────────────────────────────────
# Any model your API key can access, for example:
#   claude-opus-4-5 | claude-sonnet-4-5 | claude-3-5-haiku-20241022
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-opus-4-5

# ── Frontend ───────────────────────────────────────────────
# Set to false for a pure REST API server (no HTML UI served).
# Useful when the frontend is hosted separately or not needed.
ENABLE_FRONTEND=true

# ── Sessions ───────────────────────────────────────────────
SESSION_TTL_SECONDS=3600
MAX_SESSIONS=1000

# ── Uploads ────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ── CORS ───────────────────────────────────────────────────
# In production, restrict to your origin, e.g.:
#   ALLOWED_ORIGINS=["https://mediclear.example.com"]
ALLOWED_ORIGINS=["*"]
